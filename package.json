{
  "name": "visualizing-potential-well",
  "description": "n-dimensional infinite potential well visualization desktop app",
  "main": "electron/main.cjs",
  "private": true,
  "author": "Lequan Wang and Haibei Li",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "dev:desktop": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "icon:generate": "node scripts/generate_app_icon.cjs",
    "build": "vite build",
    "preview": "vite preview",
    "build:desktop": "npm run build && electron-builder --win portable --config.electronDist=node_modules/electron/dist && node scripts/keep_only_exe_in_release.cjs"
  },
  "dependencies": {
    "ant-design-vue": "^4.2.6",
    "html2canvas": "^1.4.1",
    "katex": "^0.16.28",
    "plotly.js-dist-min": "^3.3.1",
    "vue": "^3.5.24",
    "vue-router": "^5.0.2"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1",
    "vite": "npm:rolldown-vite@7.2.5",
    "wait-on": "^9.0.4"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@7.2.5"
  },
  "build": {
    "appId": "com.visualizingpotentialwell.desktop",
    "productName": "Visualizing Potential Well",
    "artifactName": "${productName}.exe",
    "icon": "icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "icon.ico",
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ]
    }
  }
}
